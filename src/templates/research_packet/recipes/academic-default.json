{
  "schema": "sinorag-recipe-v1",
  "name": "academic-default",
  "description": "Default scholarly recipe: phrase search, history, first attestation, timeline, canonical source, similarity from passage seeds. Full text of works contributing >=5 cited passages is included.",
  "full_work_threshold": 5,
  "context_before": 5,
  "context_after": 5,
  "steps": [
    {"tool": "phrase-index-search", "when": "phrase",  "args": {"limit": 200}},
    {"tool": "phrase-history",      "when": "phrase",  "args": {"limit": 200, "include_variants": true}},
    {"tool": "first-attestation",   "when": "phrase",  "args": {"limit": 200}},
    {"tool": "timeline",            "when": "phrase",  "args": {"limit": 200, "include_variants": true}},
    {"tool": "canonical-source",    "when": "phrase",  "args": {"limit": 100, "canon": ["T"]}},
    {"tool": "similar",             "when": "passage", "args": {"limit": 25}},
    {"tool": "person-resolve",      "when": "person",  "args": {}},
    {"tool": "person-history",      "when": "person",  "args": {"limit": 200}}
  ]
}
